DATABASE_URL=postgresql://postgres:password@host:5432/railway
SECRET_KEY=replace-with-a-48-byte-random-secret-key
ACCESS_TOKEN_EXPIRE_MINUTES=60
PUBLIC_REGISTRATION_ENABLED=false
ADMIN_BOOTSTRAP_ENABLED=false
ADMIN_USERNAME=
ADMIN_PASSWORD=
ADMIN_EMAIL=
CORS_ORIGINS=https://dpsearch.netlify.app,http://localhost:5173
WEB_CONCURRENCY=4
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40
DATABASE_POOL_TIMEOUT_SECONDS=30
DATABASE_POOL_RECYCLE_SECONDS=1800
SQLITE_BUSY_TIMEOUT_MS=15000
GZIP_MINIMUM_SIZE=1024
TOMTOM_API_KEY=your-tomtom-api-key
MOTIVE_API_KEY=your-motive-api-key
LIVE_PRICE_BACKGROUND_REFRESH_ENABLED=true
LIVE_PRICE_CACHE_TTL_SECONDS=900
LIVE_PRICE_CACHE_STALE_TTL_SECONDS=43200
LIVE_PRICE_QUEUE_WORKERS=4
LIVE_PRICE_QUEUE_MAX_SIZE=2048
STATION_CATALOG_MAX_AGE_DAYS=30
STATION_CATALOG_BACKGROUND_REFRESH_ENABLED=true
STATION_CATALOG_BLOCKING_REBUILD_ON_MISS_ENABLED=false
ROUTE_LIVE_PRICE_BLOCKING_LIMIT=18
ROUTE_LIVE_PRICE_TIMEOUT_SECONDS=12
